{
  "name": "surpluslink-root",
  "private": true,
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npx concurrently \"npm run test:backend\" \"npm run test:frontend\"",
    "test:backend": "cd backend && npm test -- --coverage",
    "test:frontend": "cd frontend && npm run test -- --coverage",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}